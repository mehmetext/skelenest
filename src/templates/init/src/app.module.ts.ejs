<%_ const includesRedis = selectedOptionIds.includes('redis'); _%>
<%_ const includesBullmq = selectedOptionIds.includes('bullmq'); _%>
<%_ const includesThrottler = selectedOptionIds.includes('throttler'); _%>
<%_ const includesElasticsearch = selectedOptionIds.includes('elasticsearch'); _%>
<%_ const includesRest = Array.isArray(apiTransports) && apiTransports.includes('rest'); _%>
<%_ const includesGraphql = Array.isArray(apiTransports) && apiTransports.includes('graphql'); _%>
<%_ if (includesRedis) { _%>
import { RedisModule } from '@nestjs-modules/ioredis';
<%_ } _%>
<%_ if (includesRedis && includesThrottler) { _%>
import { ThrottlerStorageRedisService } from '@nest-lab/throttler-storage-redis';
<%_ } _%>
<%_ if (includesBullmq) { _%>
import { BullModule } from '@nestjs/bullmq';
<%_ } _%>
import { Module } from '@nestjs/common';
import { ConfigModule<% if (includesRedis || includesBullmq || includesThrottler || includesElasticsearch) { %>, ConfigService<% } %> } from '@nestjs/config';
<%_ if (includesThrottler) { _%>
import { APP_GUARD } from '@nestjs/core';
import { ThrottlerGuard, ThrottlerModule } from '@nestjs/throttler';
<%_ } _%>
<%
const appModuleImports = getSlot('app.module.imports');
const appModuleEntries = getSlot('app.module.moduleImports');
-%>
<%_ if (appModuleImports.length > 0) { _%>
<%- appModuleImports.join('\n') %>
<%_ } _%>
<%_ if (includesGraphql) { _%>
import { AppResolver } from './app.resolver';
<%_ } _%>
<%_ if (includesRest) { _%>
import { AppController } from './app.controller';
<%_ } _%>
import { AppService } from './app.service';

@Module({
  imports: [
    ConfigModule.forRoot({
      isGlobal: true,
    }),
<%_ if (includesRedis) { _%>
    RedisModule.forRootAsync({
      useFactory: (configService: ConfigService) => ({
        type: 'single',
        url: configService.getOrThrow('REDIS_URL'),
        options: {
          keyPrefix: '<%= name %>:',
        },
      }),
      inject: [ConfigService],
    }),
<%_ } _%>
<%_ if (includesBullmq) { _%>
    BullModule.forRootAsync({
      useFactory: (configService: ConfigService) => ({
        connection: {
          keyPrefix: '<%= name %>:',
          url: configService.getOrThrow('REDIS_URL'),
        },
      }),
      inject: [ConfigService],
    }),
<%_ } _%>
<%_ if (includesThrottler) { _%>
    ThrottlerModule.forRootAsync({
      useFactory: (configService: ConfigService) => ({
        throttlers: [
          {
            name: 'short',
            ttl: 1000,
            limit: 3,
          },
          {
            name: 'medium',
            ttl: 10000,
            limit: 20,
          },
          {
            name: 'long',
            ttl: 60000,
            limit: 100,
          },
        ],
<%_ if (includesRedis) { _%>
        storage: new ThrottlerStorageRedisService(
          configService.getOrThrow('REDIS_URL'),
          {
            keyPrefix: '<%= name %>:',
          },
        ),
<%_ } _%>
      }),
      inject: [ConfigService],
    }),
<%_ } _%>
<%_ if (appModuleEntries.length > 0) { _%>
<%- appModuleEntries.map((moduleImport) => `    ${moduleImport},`).join('\n') %>
<%_ } _%>
  ],
  controllers: [<%= includesRest ? 'AppController' : '' %>],
  providers: [
    AppService,
<%_ if (includesGraphql) { _%>
    AppResolver,
<%_ } _%>
<%_ if (includesThrottler) { _%>
    {
      provide: APP_GUARD,
      useClass: ThrottlerGuard,
    },
<%_ } _%>
  ],
})
export class AppModule {}
