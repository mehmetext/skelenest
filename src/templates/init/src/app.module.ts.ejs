import { Module } from '@nestjs/common';
import { ConfigModule } from '@nestjs/config';
<%
const appModuleImports = getSlot('app.module.imports');
const appModuleEntries = getSlot('app.module.moduleImports');
-%>
<%_ if (appModuleImports.length > 0) { _%>
<%- appModuleImports.join('\n') %>
<%_ } _%>
import { AppController } from './app.controller';
import { AppService } from './app.service';

@Module({
  imports: [
    ConfigModule.forRoot({
      isGlobal: true,
    }),
<%_ if (appModuleEntries.length > 0) { _%>
<%- appModuleEntries.map((moduleImport) => `    ${moduleImport},`).join('\n') %>
<%_ } _%>
  ],
  controllers: [AppController],
  providers: [AppService],
})
export class AppModule {}
