import { ValidationPipe } from "@nestjs/common";
import { NestFactory } from "@nestjs/core";
<%_ const includesSwagger = selectedOptionIds.includes('swagger'); _%>
<%_ const includesRest = Array.isArray(apiTransports) && apiTransports.includes('rest'); _%>
<%_ if (includesSwagger) { _%>
import { DocumentBuilder, SwaggerModule } from "@nestjs/swagger";
<%_ } _%>
<%
const mainImports = getSlot('main.imports');
const mainBootstrapStatements = getSlot('main.bootstrap');
-%>
<%_ if (mainImports.length > 0) { _%>
<%- mainImports.join('\n') %>
<%_ } _%>
import { AppModule } from "./app.module";

async function bootstrap() {
  if (!process.env.PORT) {
    throw new Error("PORT is not set");
  }
  const app = await NestFactory.create(AppModule);

  app.useGlobalPipes(
    new ValidationPipe({
      whitelist: true,
      forbidNonWhitelisted: true,
      transform: true,
      transformOptions: { enableImplicitConversion: true },
      stopAtFirstError: true,
    })
  );
<%_ if (includesSwagger && includesRest) { _%>

  const config = new DocumentBuilder()
    .setTitle('<%= projectDisplayName %>')
    .setDescription('<%= projectDisplayName %> API description')
    .setVersion('1.0')
    .addTag('<%= name %>')
    .addBearerAuth()
    .build();

  const documentFactory = () => SwaggerModule.createDocument(app, config);
  SwaggerModule.setup('api/docs', app, documentFactory, {
    swaggerOptions: {
      persistAuthorization: true,
    },
  });
<%_ } _%>
<%_ if (mainBootstrapStatements.length > 0) { _%>
<%- mainBootstrapStatements.map((statement) => `  ${statement}`).join('\n') %>
<%_ } _%>
  await app.listen(process.env.PORT);
}
void bootstrap();
