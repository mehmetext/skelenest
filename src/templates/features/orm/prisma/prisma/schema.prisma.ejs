generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

<%
const prismaSchemaModels = getSlot('prisma.schema.models');
-%>
<%_ if (prismaSchemaModels.length > 0) { _%>

<%- prismaSchemaModels.join('\n\n') %>
<%_ } _%>
