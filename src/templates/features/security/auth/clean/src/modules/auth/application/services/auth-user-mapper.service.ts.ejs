<%_ if (selectedOptionIds.includes('sequelize')) { _%>
import type { UserModel } from '../../../../database/models/user.model';
<%_ } else { _%>
import type { User } from 'src/generated/prisma/client';
<%_ } _%>
import { Injectable } from '@nestjs/common';
import type { AuthResponseDto, AuthUserDto } from '../dto/auth.dto';

@Injectable()
export class AuthUserMapperService {
  toAuthResponse(
    user: <%_ if (selectedOptionIds.includes('sequelize')) { _%>UserModel<%_ } else { _%>User<%_ } _%>,
    tokens: { accessToken: string; refreshToken: string },
  ): AuthResponseDto {
    return {
      user: this.toAuthUser(user),
      accessToken: tokens.accessToken,
      refreshToken: tokens.refreshToken,
    };
  }

  toAuthUser(user: <%_ if (selectedOptionIds.includes('sequelize')) { _%>UserModel<%_ } else { _%>User<%_ } _%>): AuthUserDto {
    return {
      id: user.id,
      email: user.email,
      firstName: user.firstName,
      lastName: user.lastName,
    };
  }
}
