<%_ if (selectedOptionIds.includes('sequelize')) { _%>
import type { UserModel } from '../../../../database/models/user.model';
<%_ } else if (selectedOptionIds.includes('typeorm')) { _%>
import type { UserEntity } from '../../../../database/entities/user.entity';
<%_ } else { _%>
import type { User } from 'src/generated/prisma/client';
<%_ } _%>
import { Inject, Injectable } from '@nestjs/common';
import { AUTH_SESSION_STORE } from '../ports/auth-session-store.port';
import type { AuthSessionStore } from '../ports/auth-session-store.port';
import { AUTH_TOKEN_SERVICE } from '../ports/auth-token-service.port';
import type { AuthTokenService } from '../ports/auth-token-service.port';

@Injectable()
export class AuthTokenOrchestratorService {
  constructor(
    @Inject(AUTH_TOKEN_SERVICE)
    private readonly authTokenService: AuthTokenService,
    @Inject(AUTH_SESSION_STORE)
    private readonly authSessionStore: AuthSessionStore,
  ) {}

  async issueForUser(user: <%_ if (selectedOptionIds.includes('sequelize')) { _%>UserModel<%_ } else if (selectedOptionIds.includes('typeorm')) { _%>UserEntity<%_ } else { _%>User<%_ } _%>) {
    const tokens = await this.authTokenService.issueTokens({
      userId: user.id,
      email: user.email,
    });

    await this.authSessionStore.persistRefreshToken({
      refreshToken: tokens.refreshToken,
      payload: {
        sub: user.id,
        jti: tokens.refreshTokenJti,
        type: 'refresh',
      },
      userId: user.id,
      ttlSeconds: tokens.refreshTokenTtlSeconds,
    });

    return tokens;
  }
}
