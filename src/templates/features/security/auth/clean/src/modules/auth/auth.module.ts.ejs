<%_ const includesRedis = selectedOptionIds.includes('redis'); _%>
<%_ const isSequelize = selectedOptionIds.includes('sequelize'); _%>
<%_ const isTypeOrm = selectedOptionIds.includes('typeorm'); _%>
<%_ const authTransportsValue = Array.isArray(authTransports) ? authTransports : ['rest']; _%>
<%_ const includesRest = authTransportsValue.includes('rest'); _%>
<%_ const includesGraphql = authTransportsValue.includes('graphql'); _%>
import { Module } from '@nestjs/common';
import { ConfigModule, ConfigService } from '@nestjs/config';
import { JwtModule } from '@nestjs/jwt';
import { PassportModule } from '@nestjs/passport';
<%_ if (isSequelize && !includesRedis) { _%>
import { SequelizeModule } from '@nestjs/sequelize';
import { RefreshSessionModel } from '../../database/models/refresh-session.model';
import { RevokedAccessTokenModel } from '../../database/models/revoked-access-token.model';
<%_ } _%>
<%_ if (isTypeOrm && !includesRedis) { _%>
import { TypeOrmModule } from '@nestjs/typeorm';
import { RefreshSessionEntity } from '../../database/entities/refresh-session.entity';
import { RevokedAccessTokenEntity } from '../../database/entities/revoked-access-token.entity';
<%_ } _%>
import { UsersModule } from '../users/users.module';
import {
  AUTH_SESSION_STORE,
} from './application/ports/auth-session-store.port';
import {
  AUTH_TOKEN_SERVICE,
} from './application/ports/auth-token-service.port';
import {
  PASSWORD_HASHER,
} from './application/ports/password-hasher.port';
import { GetMeUseCase } from './application/use-cases/get-me.use-case';
import { IssueAuthResponseUseCase } from './application/use-cases/issue-auth-response.use-case';
import { LogoutUseCase } from './application/use-cases/logout.use-case';
import { RefreshTokenUseCase } from './application/use-cases/refresh-token.use-case';
import { RegisterUseCase } from './application/use-cases/register.use-case';
import { ValidateUserUseCase } from './application/use-cases/validate-user.use-case';
import { AuthTokenOrchestratorService } from './application/services/auth-token-orchestrator.service';
import { AuthUserMapperService } from './application/services/auth-user-mapper.service';
<%_ if (!includesRedis && !isSequelize && !isTypeOrm) { _%>
import { PrismaAuthSessionStoreAdapter } from './infrastructure/cache/prisma-auth-session-store.adapter';
<%_ } _%>
<%_ if (!includesRedis && isSequelize) { _%>
import { SequelizeAuthSessionStoreAdapter } from './infrastructure/cache/sequelize-auth-session-store.adapter';
<%_ } _%>
<%_ if (!includesRedis && isTypeOrm) { _%>
import { TypeOrmAuthSessionStoreAdapter } from './infrastructure/cache/typeorm-auth-session-store.adapter';
<%_ } _%>
<%_ if (includesRedis) { _%>
import { RedisAuthSessionStoreAdapter } from './infrastructure/cache/redis-auth-session-store.adapter';
<%_ } _%>
import { JwtAuthTokenAdapter } from './infrastructure/security/jwt-auth-token.adapter';
import { ScryptPasswordHasherAdapter } from './infrastructure/security/scrypt-password-hasher.adapter';
<%_ if (includesRest) { _%>
import { AuthController } from './presentation/http/auth.controller';
<%_ } _%>
<%_ if (includesGraphql) { _%>
import { AuthResolver } from './presentation/graphql/auth.resolver';
<%_ } _%>
import { JwtAuthGuard } from './presentation/http/guards/jwt-auth.guard';
import { LocalAuthGuard } from './presentation/http/guards/local-auth.guard';
import { JwtStrategy } from './presentation/http/strategies/jwt.strategy';
import { LocalStrategy } from './presentation/http/strategies/local.strategy';

@Module({
  imports: [
    ConfigModule,
    PassportModule,
    UsersModule,
<%_ if (isSequelize && !includesRedis) { _%>
    SequelizeModule.forFeature([RefreshSessionModel, RevokedAccessTokenModel]),
<%_ } _%>
<%_ if (isTypeOrm && !includesRedis) { _%>
    TypeOrmModule.forFeature([RefreshSessionEntity, RevokedAccessTokenEntity]),
<%_ } _%>
    JwtModule.registerAsync({
      imports: [ConfigModule],
      inject: [ConfigService],
      useFactory: (configService: ConfigService) => ({
        secret: configService.getOrThrow<string>('JWT_ACCESS_SECRET'),
      }),
    }),
  ],
  controllers: [<%= includesRest ? 'AuthController' : '' %>],
  providers: [
<%_ if (includesGraphql) { _%>
    AuthResolver,
<%_ } _%>
    RegisterUseCase,
    ValidateUserUseCase,
    IssueAuthResponseUseCase,
    RefreshTokenUseCase,
    LogoutUseCase,
    GetMeUseCase,
    AuthTokenOrchestratorService,
    AuthUserMapperService,
    JwtAuthGuard,
    LocalAuthGuard,
    JwtStrategy,
    LocalStrategy,
    {
      provide: PASSWORD_HASHER,
      useClass: ScryptPasswordHasherAdapter,
    },
    {
      provide: AUTH_TOKEN_SERVICE,
      useClass: JwtAuthTokenAdapter,
    },
    {
      provide: AUTH_SESSION_STORE,
<%_ if (includesRedis) { _%>
      useClass: RedisAuthSessionStoreAdapter,
<%_ } else if (isSequelize) { _%>
      useClass: SequelizeAuthSessionStoreAdapter,
<%_ } else if (isTypeOrm) { _%>
      useClass: TypeOrmAuthSessionStoreAdapter,
<%_ } else { _%>
      useClass: PrismaAuthSessionStoreAdapter,
<%_ } _%>
    },
  ],
  exports: [
    RegisterUseCase,
    ValidateUserUseCase,
    IssueAuthResponseUseCase,
    RefreshTokenUseCase,
    LogoutUseCase,
    GetMeUseCase,
  ],
})
export class AuthModule {}
