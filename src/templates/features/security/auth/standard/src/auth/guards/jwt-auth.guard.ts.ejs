<%_ const includesRedis = selectedOptionIds.includes('redis'); _%>
<%_ const isSequelize = selectedOptionIds.includes('sequelize'); _%>
<%_ const isTypeOrm = selectedOptionIds.includes('typeorm'); _%>
<%_ const includesGraphql = Array.isArray(apiTransports) && apiTransports.includes('graphql'); _%>
<%_ if (!includesRedis) { _%>
<%_ if (isSequelize) { _%>
import { InjectModel } from "@nestjs/sequelize";
import { RevokedAccessTokenModel } from "../../database/models/revoked-access-token.model";
<%_ } else if (isTypeOrm) { _%>
import { InjectRepository } from "@nestjs/typeorm";
import { RevokedAccessTokenEntity } from "../../database/entities/revoked-access-token.entity";
import { Repository } from "typeorm";
<%_ } else { _%>
import { PrismaService } from "src/prisma/prisma.service";
<%_ } _%>
<%_ } _%>
import { ExecutionContext, Injectable<% if (includesRedis || isSequelize || isTypeOrm) { %>, UnauthorizedException<% } %> } from "@nestjs/common";
import { AuthGuard } from "@nestjs/passport";
<%_ if (includesGraphql) { _%>
import { GqlExecutionContext } from "@nestjs/graphql";
<%_ } _%>
import type { Request } from "express";
<%_ if (includesRedis) { _%>
import { InjectRedis } from "@nestjs-modules/ioredis";
import { Redis } from "ioredis";
import { BLOCKLIST_KEY } from "../auth.constants";
<%_ } _%>
import type { AuthenticatedRequestUser } from "../types";

@Injectable()
export class JwtAuthGuard extends AuthGuard("jwt") {
<%_ if (includesRedis) { _%>
  constructor(@InjectRedis() private readonly redis: Redis) {
    super();
  }
<%_ } else { _%>
  constructor(<%_ if (isSequelize) { _%>@InjectModel(RevokedAccessTokenModel) private readonly revokedAccessTokens: typeof RevokedAccessTokenModel<%_ } else if (isTypeOrm) { _%>@InjectRepository(RevokedAccessTokenEntity) private readonly revokedAccessTokens: Repository<RevokedAccessTokenEntity><%_ } else { _%>private readonly prisma: PrismaService<%_ } _%>) {
    super();
  }
<%_ } _%>

  async canActivate(context: ExecutionContext): Promise<boolean> {
    const result = await (super.canActivate(context) as Promise<boolean>);
    if (!result) return false;

    const request = this.getRequest(context);
<%_ if (includesRedis) { _%>
    const user = request.user as AuthenticatedRequestUser;
    const blocked = await this.redis.exists(BLOCKLIST_KEY(user.jti));
    if (blocked) throw new UnauthorizedException("Token has been revoked");
<%_ } else { _%>
    const user = request.user as AuthenticatedRequestUser;
    const blocked = await <% if (isSequelize) { %>this.revokedAccessTokens.findOne({
      where: { jti: user.jti },
    })<% } else if (isTypeOrm) { %>this.revokedAccessTokens.findOne({
      where: { jti: user.jti },
    })<% } else { %>this.prisma.revokedAccessToken.findUnique({
      where: { jti: user.jti },
      select: { expiresAt: true },
    })<% } %>;
    if (blocked && blocked.expiresAt.getTime() > Date.now()) {
      throw new UnauthorizedException("Token has been revoked");
    }
<%_ } _%>

    return true;
  }

  getRequest(context: ExecutionContext): Request {
<%_ if (includesGraphql) { _%>
    if (context.getType<string>() === "graphql") {
      return GqlExecutionContext.create(context).getContext<{ req: Request }>().req;
    }
<%_ } _%>
    return context.switchToHttp().getRequest<Request>();
  }
}
