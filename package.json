{
  "name": "skelenest",
  "version": "1.0.3",
  "description": "An opinionated CLI for scaffolding NestJS projects",
  "scripts": {
    "dev": "rm -rf dist && tsx watch bin/skelenest.ts",
    "build": "rm -rf dist && tsup bin/skelenest.ts src/**/*.ts --format cjs --dts && chmod +x dist/bin/skelenest.js && cpx \"src/templates/**/*\" dist/src/templates && cpx \"src/templates/**/.[!.]*\" dist/src/templates",
    "start": "node ./dist/bin/skelenest.js",
    "dev:init": "pnpm build && skelenest init",
    "prepublishOnly": "pnpm build"
  },
  "bin": {
    "skelenest": "dist/bin/skelenest.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "nest",
    "nestjs",
    "cli",
    "scaffold",
    "boilerplate"
  ],
  "author": "Mehmet Konukcu <mehmetext68@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mehmetext/skelenest.git"
  },
  "homepage": "https://github.com/mehmetext/skelenest#readme",
  "bugs": {
    "url": "https://github.com/mehmetext/skelenest/issues"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ejs": "^5.0.2",
    "figlet": "^1.11.0",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "cpx2": "^8.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
